#  WhatsApp / Meta Cloud API 
WHATSAPP_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=any_random_string_you_choose   # e.g. "wcbot_secret_2026"

#  TxLINE 
# Step 1: Get JWT -> POST https://txline.txodds.com/auth/guest/start (no auth needed)
TXLINE_JWT=your_guest_jwt_here
# Step 2: Activate subscription on-chain -> POST https://txline.txodds.com/api/token/activate
TXLINE_API_KEY=your_activated_api_token_here
TXLINE_BASE_URL=https://txline.txodds.com/api

#  Groq AI 
GROQ_API_KEY=your_groq_api_key_here

#  App 
PORT=3000
NODE_ENV=development
